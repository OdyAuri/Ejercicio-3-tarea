// Primer ejercicio de matrices de la clase 
#include <stdio.h>
void main ()
{
    int matriz1[2][2] = {{1,1},{1,1}};
    int i, j;
    printf("Imprimir Matriz uno\n");
    for (i=0 ; i<2 ; i++)
    {
        for (j=0 ; j<2 ; j++)
        {
            printf("%d, ",matriz1[i][j]); 
        }
     printf("\n");
    }
		
